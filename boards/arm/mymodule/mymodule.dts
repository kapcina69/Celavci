/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>

/ {
    model = "myModule";
    compatible = "mymodule";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &slot0_partition;
    };

    leds {
        compatible = "gpio-leds";
        led0: led_0 {
            gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;
            label = "Green LED 0";
        };
        led1: led_1 {
            gpios = <&gpio0 6 GPIO_ACTIVE_LOW>;
            label = "Green LED 1";
        };
    };

    /* Custom GPIO definitions */
    custom_gpios {
        compatible = "gpio-keys";
        
        pulse_cathode: pulse_cathode {
            gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
            label = "Pulse cathode";
        };
        pulse_anode: pulse_anode {
            gpios = <&gpio0 24 GPIO_ACTIVE_HIGH>;
            label = "Pulse anode";
        };
        dc_dc_en: dc_dc_en {
            gpios = <&gpio0 17 GPIO_ACTIVE_HIGH>;
            label = "DC-DC enable";
        };

        gpio8_out: gpio8_out {
            gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>;
            label = "GPIO Output 8";
        };
        gpio13_out: gpio13_out {
            gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;
            label = "GPIO Output 13";
        };
        gpio14_out: gpio14_out {
            gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>;
            label = "GPIO Output 14";
        };
        gpio15_out: gpio15_out {
            gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
            label = "GPIO Output 15";
        };
    };

    aliases {
        led0 = &led0;
        led1 = &led1;
        pulse-cathode = &pulse_cathode;
        pulse-anode = &pulse_anode;
        dc-dc-en = &dc_dc_en;
        i2c0 = &i2c0;

        gpio8-out = &gpio8_out;
        gpio13-out = &gpio13_out;
        gpio14-out = &gpio14_out;
        gpio15-out = &gpio15_out;
    };
};

&pinctrl {
    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 26)>,
                    <NRF_PSEL(TWIM_SCL, 0, 27)>;
        };
    };

	spi1_default: spi1_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 19)>,
                    <NRF_PSEL(SPIM_SCK, 0, 23)>;
        };
    };

    spi1_sleep: spi1_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 19)>,
                    <NRF_PSEL(SPIM_SCK, 0, 23)>;
            low-power-enable;
        };
    };
};

&i2c0 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-names = "default";
    clock-frequency = <I2C_BITRATE_STANDARD>;

    dac@60 {
        compatible = "microchip,mcp4716";
        reg = <0x60>;
        label = "MCP4716A3T";
        #io-channel-cells = <1>;
    };
};

/* MULTIPLEXER */
&spi1 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 22 GPIO_ACTIVE_LOW>;
	mux_stim: hv2607@0 {
		compatible = "microchip,mcp3562";
		reg = <0>;
		spi-max-frequency = <2000000>;
	};
};

&gpio0 {
    status = "okay";
};

&gpiote {
    status = "okay";
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x0 0xc000>;
        };
        slot0_partition: partition@c000 {
            label = "image-0";
            reg = <0xc000 0x72000>;
        };
        slot1_partition: partition@7e000 {
            label = "image-1";
            reg = <0x7e000 0x72000>;
        };
        scratch_partition: partition@f0000 {
            label = "image-scratch";
            reg = <0xf0000 0xa000>;
        };
        storage_partition: partition@fa000 {
            label = "storage";
            reg = <0xfa000 0x6000>;
        };
    };
};
